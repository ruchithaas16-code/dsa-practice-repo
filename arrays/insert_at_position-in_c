#include <stdio.h>

void insert(int *n, int a[], int pos, int key) {
    // Shift elements from the end to pos one position to the right
    for (int i = *n; i >= pos; i--) {
        a[i] = a[i - 1];
    }
    a[pos - 1] = key;    // Insert key at correct 1‑based index
    (*n)++;              // Increase size
}

int main() {
    int arr[100];        // Fixed max size
    int size, pos, value;

    printf("Enter size of array: ");
    scanf("%d", &size);

    printf("Enter %d elements: ", size);
    for (int i = 0; i < size; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter position (1-based): ");
    scanf("%d", &pos);

    printf("Enter element: ");
    scanf("%d", &value);

    // Optional: validate position
    if (pos < 1 || pos > size + 1) {
        printf("Invalid position!\n");
        return 1;
    }

    insert(&size, arr, pos, value);

    printf("Array after insertion: ");
    for (int i = 0; i < size; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    return 0;
}
