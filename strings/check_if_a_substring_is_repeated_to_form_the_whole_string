def is_repeated_substring(s):
    n = len(s)
    for i in range(1, n // 2 + 1):
        if n % i == 0:
            pattern = s[:i]
            if pattern * (n // i) == s:
                return True
    return False

print(is_repeated_substring("abcabcabc"))  # True
print(is_repeated_substring("abcde"))      # False
